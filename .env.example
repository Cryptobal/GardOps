# Base de datos
DATABASE_URL=postgresql://username:password@localhost:5432/gardapp

# Google Maps API para autocompletado de direcciones
# Obtener en: https://console.cloud.google.com/google/maps-apis/
# Asegúrate de habilitar: Places API, Maps JavaScript API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Configuración de la aplicación
NEXT_PUBLIC_APP_URL=http://localhost:3000 